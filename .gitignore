# ════════════════════════════════════════════════════════════
#  Tech-Fix-Bible · .gitignore
# ════════════════════════════════════════════════════════════

# ── Secrets (HARD BLOCK) ────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.pfx
*credentials*.json
!*credentials.example.json

# ── Python / FastAPI ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
.python-version
pyrightconfig.json

# ── Node / Next.js ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.next/
out/
build/
dist/
.turbo/
.swc/
*.tsbuildinfo
next-env.d.ts

# ── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS cruft ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editors / IDEs ──────────────────────────────────────────
.idea/
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Deployment / infra ──────────────────────────────────────
.vercel
.railway
.netlify
.terraform/
*.tfstate
*.tfstate.*
.serverless/

# ── Database dumps / local state ────────────────────────────
*.sqlite
*.sqlite3
*.db
*.dump
*.sql.gz
/data/
/pgdata/

# ── Build artifacts ─────────────────────────────────────────
/coverage
/public/sw.js
/public/workbox-*.js
storybook-static/

# ── Misc ────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
tmp/
temp/

# ── DB backups (v1.2.1 prep) ────────────────────────────────
backup_pre_*

# ── Patch artifacts (temporary, not code) ───────────────────
techkb-patch-*.zip

# Local DB backups (do not commit)
backups/
