# ════════════════════════════════════════════════════════════
#  Tech-Fix-Bible · Root env template
#  Copy to .env and fill with real values (NEVER commit .env)
# ════════════════════════════════════════════════════════════
#
# This file documents every env var the stack uses. The actual
# values live in:
#   backend/.env         (FastAPI process)
#   frontend/.env.local  (Next.js build/runtime)
#
# Keep this file in sync when new variables are introduced.
# ════════════════════════════════════════════════════════════

# ── Backend · database ──────────────────────────────────────
# asyncpg driver required (SQLAlchemy async engine)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/tech_fix_bible

# ── Backend · auth ──────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=replace-with-32-byte-random-hex

# ── Backend · Google OAuth2 ─────────────────────────────────
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# ── Backend · admin bootstrap (promote-only) ────────────────
# Comma-separated emails auto-promoted on first Google login.
# Removal does NOT revoke — use the revoke endpoint or UPDATE SQL.
ADMIN_EMAILS=your.email@gmail.com

# ── Backend · app behavior ──────────────────────────────────
FRONTEND_URL=http://localhost:3000
HEALTH_CHECK_HOURS=6

# ── Frontend · public API URL ───────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
